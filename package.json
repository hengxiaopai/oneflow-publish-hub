{
  "name": "oneflow-publish-hub",
  "version": "0.4.1",
  "private": true,
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "node scripts/static-server.mjs",
    "dev:server": "npm --prefix server run dev",
    "dev:fake-halo": "npm --prefix server run dev:fake-halo",
    "test": "npm run test:frontend && npm run test:server",
    "test:frontend": "node --test tests/*.test.js",
    "test:server": "npm --prefix server test",
    "test:halo-smoke": "npm --prefix server run test:halo-smoke",
    "lint": "npm run check",
    "check": "node scripts/check.mjs && npm --prefix server run prisma:validate && npm --prefix server run prisma:validate:postgres",
    "security:scan": "node scripts/scan-sensitive.mjs",
    "db:generate": "npm --prefix server run prisma:generate",
    "db:migrate": "npm --prefix server run prisma:migrate",
    "db:seed": "npm --prefix server run prisma:seed",
    "db:reset": "npm --prefix server run prisma:reset"
  }
}
