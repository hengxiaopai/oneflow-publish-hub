# Docker Compose development values only. Do not reuse these secrets in production.
NODE_ENV=development
PORT=4174
DATABASE_URL=file:/app/data/oneflow.db
ENCRYPTION_KEY=replace-with-a-random-encryption-key-at-least-32-characters
SESSION_SECRET=replace-with-a-different-session-secret-at-least-32-characters
SESSION_COOKIE_NAME=oneflow_session
SESSION_TTL_HOURS=168
CORS_ORIGIN=http://127.0.0.1:4173,http://localhost:4173
