NODE_ENV=development
PORT=4174
HOST=127.0.0.1
DATABASE_URL=file:./dev.db
# Production migration target. Prisma providers are selected by schema file.
POSTGRES_DATABASE_URL=postgresql://oneflow:change-me@127.0.0.1:5432/oneflow
ENCRYPTION_KEY=replace-with-a-long-random-local-development-key
SESSION_SECRET=replace-with-a-different-long-random-session-secret
SESSION_COOKIE_NAME=oneflow_session
SESSION_TTL_HOURS=168
CORS_ORIGIN=http://127.0.0.1:4173
BODY_LIMIT=3145728
AUTH_RATE_LIMIT_MAX=12
DEV_SESSION_RATE_LIMIT_MAX=20
PUBLISH_RATE_LIMIT_MAX=30
ALLOW_PRIVATE_HALO_URLS=false
HALO_REQUEST_TIMEOUT_MS=15000
DEMO_USER_EMAIL=
DEMO_USER_NAME=OneFlow Developer
DEMO_USER_PASSWORD=
