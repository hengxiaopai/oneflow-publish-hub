generator client {
  provider = "prisma-client-js"
  output   = "../generated/postgresql"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String            @id @default(cuid())
  devProfileKey   String?           @unique
  email           String?           @unique
  name            String
  avatarUrl       String?
  passwordHash    String?
  status          String            @default("active")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  memberships     WorkspaceMember[]
  sessions        Session[]
  authIdentities  AuthIdentity[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
}

model Workspace {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  ownerId         String?
  plan            String            @default("free")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  owner           User?             @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members         WorkspaceMember[]
  sessions        Session[]
  articles        Article[]
  channels        ChannelConfig[]
  channelVersions ChannelVersion[]
  publishBatches  PublishBatch[]
  publishTasks    PublishTask[]
  publishTaskEvents PublishTaskEvent[]
  aiCapabilities  AICapability[]
  usageRecords    UsageRecord[]
  validationIssues ValidationIssue[]
  subscription    Subscription?

  @@index([ownerId])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("owner")
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  tokenHash   String    @unique
  kind        String    @default("auth")
  expiresAt   DateTime
  userAgent   String?
  ipHash      String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([expiresAt])
}

model AuthIdentity {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
}

model Article {
  id              String           @id @default(cuid())
  workspaceId     String
  title           String
  slug            String           @default("")
  summary         String           @default("")
  contentHtml     String           @default("")
  contentMarkdown String           @default("")
  tags            String           @default("[]")
  cover           String           @default("{}")
  status          String           @default("draft")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channelVersions ChannelVersion[]
  publishBatches  PublishBatch[]

  @@index([workspaceId, updatedAt])
}

model ChannelConfig {
  id                  String           @id @default(cuid())
  workspaceId         String
  platformId          String
  displayName         String
  channelType         String           @default("article")
  configuration       String           @default("{}")
  publisherMode       String           @default("mock")
  encryptedCredential String?
  credentialStatus    String           @default("none")
  connectionStatus    String           @default("not_connected")
  mockBehavior        String           @default("success")
  lastVerifiedAt      DateTime?
  lastTestedAt        DateTime?
  lastTestStatus      String?
  lastTestMessage     String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  workspace           Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channelVersions     ChannelVersion[]
  publishTasks        PublishTask[]

  @@unique([workspaceId, platformId, displayName])
  @@index([workspaceId, connectionStatus])
}

model ChannelVersion {
  id              String        @id @default(cuid())
  workspaceId     String
  articleId       String
  channelConfigId String
  title           String
  summary         String        @default("")
  contentHtml     String        @default("")
  contentMarkdown String        @default("")
  tags            String        @default("[]")
  metadata        String        @default("{}")
  status          String        @default("ready")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  article         Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  channelConfig   ChannelConfig @relation(fields: [channelConfigId], references: [id], onDelete: Cascade)
  publishTasks    PublishTask[]

  @@unique([articleId, channelConfigId])
  @@index([workspaceId, status])
}

model PublishBatch {
  id              String        @id @default(cuid())
  workspaceId     String
  articleId       String?
  strategy        String        @default("automatic_first")
  status          String        @default("pending")
  scheduleAt      DateTime?
  postActions     String        @default("[]")
  articleSnapshot String
  createdAt       DateTime      @default(now())
  completedAt     DateTime?
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  article         Article?      @relation(fields: [articleId], references: [id], onDelete: SetNull)
  tasks           PublishTask[]

  @@index([workspaceId, createdAt])
}

model PublishTask {
  id                     String          @id @default(cuid())
  workspaceId            String
  publishBatchId         String
  channelConfigId        String?
  channelVersionId       String?
  status                 String          @default("pending")
  idempotencyKey         String          @default("")
  lockedAt               DateTime?
  lockOwner              String?
  channelVersionSnapshot String
  result                 String?
  remoteUrl              String?
  remotePostId           String?
  remotePostName         String?
  remoteEditUrl          String?
  remotePreviewUrl       String?
  remotePublicUrl        String?
  remoteStatus           String?
  draftCreatedAt         DateTime?
  publishedAt            DateTime?
  lastSyncAt             DateTime?
  rawResponseSummary     String?
  errorMessage           String?
  lastErrorCode          String?
  lastErrorMessage       String?
  retryable              Boolean         @default(false)
  retryCount             Int             @default(0)
  maxRetries             Int             @default(3)
  nextRetryAt            DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  durationMs             Int?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  workspace              Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishBatch           PublishBatch    @relation(fields: [publishBatchId], references: [id], onDelete: Cascade)
  channelConfig          ChannelConfig?  @relation(fields: [channelConfigId], references: [id], onDelete: SetNull)
  channelVersion         ChannelVersion? @relation(fields: [channelVersionId], references: [id], onDelete: SetNull)
  validationIssues       ValidationIssue[]
  events                 PublishTaskEvent[]

  @@index([workspaceId, status])
  @@index([workspaceId, idempotencyKey])
  @@index([publishBatchId])
}

model PublishTaskEvent {
  id               String      @id @default(cuid())
  workspaceId      String
  publishTaskId    String
  type             String
  message          String
  metadata         String      @default("{}")
  safeRemoteStatus String?
  durationMs       Int?
  createdAt        DateTime    @default(now())
  workspace        Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishTask      PublishTask @relation(fields: [publishTaskId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([publishTaskId, createdAt])
}

model ValidationIssue {
  id            String       @id @default(cuid())
  workspaceId   String
  publishTaskId String?
  code          String
  severity      String       @default("error")
  field         String?
  message       String
  createdAt     DateTime     @default(now())
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishTask   PublishTask? @relation(fields: [publishTaskId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([publishTaskId])
}

model AICapability {
  id                 String    @id @default(cuid())
  workspaceId        String
  capabilityId       String
  name               String
  enabled            Boolean   @default(false)
  automaticExecution Boolean   @default(false)
  humanConfirmation  Boolean   @default(true)
  minimumPlan        String    @default("free")
  promptTemplate     String    @default("")
  inputFields        String    @default("[]")
  outputFields       String    @default("[]")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, capabilityId])
}

model UsageRecord {
  id          String    @id @default(cuid())
  workspaceId String
  type        String
  quantity    Int       @default(1)
  period      String
  metadata    String    @default("{}")
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, period, type])
}

model Subscription {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  planId      String    @default("free")
  status      String    @default("active")
  currentFrom DateTime  @default(now())
  currentTo   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
